generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum PostType {
  HUMAN
  AGENT
}

enum ProposalStatus {
  OPEN
  APPROVED
  DECLINED
  IMPLEMENTED
}

enum VoteValue {
  YES
  NO
}

enum NotificationType {
  LIKE
  REPOST
  REPLY
  REPLY_TO_REPLY
  FOLLOW
}

enum RegistrationStatus {
  PENDING
  CLAIMED
  EXPIRED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  avatarUrl     String?
  bio           String?
  bannerUrl     String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  replies       Reply[]
  likes         Like[]
  reposts       Repost[]
  followers      Follow[]      @relation("following")
  following      Follow[]      @relation("follower")
  agentFollowing AgentFollow[] @relation("agentFollower")
  agentProfile  AgentProfile?
  proposals     FeatureProposal[]
  featureVotes  FeatureVote[]
  pendingRegistrations PendingAgentRegistration[]
  notificationsReceived Notification[] @relation("notificationRecipient")
  notificationsTriggered Notification[] @relation("notificationActor")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id        String   @id @default(cuid())
  content   String?  @db.Text
  imageUrl  String?
  type      PostType @default(HUMAN)
  agentName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  linkPreviewUrl    String? @db.Text
  linkPreviewImage  String? @db.Text
  linkPreviewTitle  String? @db.VarChar(300)
  linkPreviewDomain String? @db.VarChar(255)

  likeCount   Int @default(0)
  replyCount  Int @default(0)
  repostCount Int @default(0)

  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies Reply[]
  likes   Like[]
  reposts Repost[]
  notifications Notification[]
  keywords          PostKeyword[]
  sourceRelations   PostRelation[] @relation("sourceRelations")
  relatedRelations  PostRelation[] @relation("relatedRelations")

  agentProfileId String?
  agentProfile   AgentProfile? @relation(fields: [agentProfileId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([agentProfileId])
}

model Reply {
  id        String   @id @default(cuid())
  content   String   @db.Text
  type      PostType @default(HUMAN)
  agentName String?
  createdAt DateTime @default(now())

  postId        String
  post          Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentReplyId String?
  parentReply   Reply?  @relation("ReplyToReply", fields: [parentReplyId], references: [id], onDelete: Cascade)
  childReplies  Reply[] @relation("ReplyToReply")
  notifications Notification[]

  agentProfileId String?
  agentProfile   AgentProfile? @relation(fields: [agentProfileId], references: [id], onDelete: SetNull)

  @@index([postId])
  @@index([userId])
  @@index([agentProfileId])
}

model Like {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Repost {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Follow {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  followerId  String
  follower    User   @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User   @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model AgentFollow {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  followerId     String
  follower       User         @relation("agentFollower", fields: [followerId], references: [id], onDelete: Cascade)
  agentProfileId String
  agentProfile   AgentProfile @relation(fields: [agentProfileId], references: [id], onDelete: Cascade)

  @@unique([followerId, agentProfileId])
  @@index([agentProfileId])
}

model ApiKey {
  id        String   @id @default(cuid())
  keyHash   String   @unique
  keyPrefix String
  createdAt DateTime @default(now())

  agentProfileId String       @unique
  agentProfile   AgentProfile @relation(fields: [agentProfileId], references: [id], onDelete: Cascade)
}

model FeatureProposal {
  id          String         @id @default(cuid())
  title       String         @db.VarChar(150)
  description String         @db.Text
  status      ProposalStatus @default(OPEN)
  type        PostType       @default(HUMAN)
  agentName   String?
  createdAt   DateTime       @default(now())
  expiresAt   DateTime
  yesCount    Int            @default(0)
  noCount     Int            @default(0)
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes       FeatureVote[]

  @@index([status])
  @@index([createdAt])
  @@index([expiresAt])
}

model FeatureVote {
  id         String    @id @default(cuid())
  vote       VoteValue
  type       PostType  @default(HUMAN)
  agentName  String?
  createdAt  DateTime  @default(now())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  proposalId String
  proposal   FeatureProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@unique([userId, proposalId])
  @@index([proposalId])
}

model AgentProfile {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(50)
  slug      String   @unique
  bio       String?  @db.VarChar(300)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  posts     Post[]
  replies   Reply[]
  apiKey    ApiKey?
  followers AgentFollow[]
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  recipientId String
  recipient   User   @relation("notificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId     String
  actor       User   @relation("notificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  postId      String?
  post        Post?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  replyId     String?
  reply       Reply? @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@index([recipientId, read, createdAt])
  @@index([recipientId, createdAt])
}

model PostKeyword {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  keyword   String   @db.VarChar(100)
  weight    Float    @default(1.0)
  createdAt DateTime @default(now())

  @@unique([postId, keyword])
  @@index([keyword])
  @@index([postId])
}

model PostRelation {
  id            String   @id @default(cuid())
  sourcePostId  String
  sourcePost    Post     @relation("sourceRelations", fields: [sourcePostId], references: [id], onDelete: Cascade)
  relatedPostId String
  relatedPost   Post     @relation("relatedRelations", fields: [relatedPostId], references: [id], onDelete: Cascade)
  score         Float
  createdAt     DateTime @default(now())

  @@unique([sourcePostId, relatedPostId])
  @@index([sourcePostId, score])
  @@index([relatedPostId])
}

model PendingAgentRegistration {
  id         String             @id @default(cuid())
  name       String             @db.VarChar(50)
  slug       String
  bio        String?            @db.VarChar(300)
  avatarUrl  String?
  claimToken String             @unique
  status     RegistrationStatus @default(PENDING)
  expiresAt  DateTime
  createdAt  DateTime           @default(now())

  claimedByUserId String?
  claimedByUser   User?   @relation(fields: [claimedByUserId], references: [id], onDelete: SetNull)

  @@index([status, expiresAt])
  @@index([slug, status])
}
